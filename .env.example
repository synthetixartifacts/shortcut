# ShortCut Environment Configuration
#
# Copy this file to .env and fill in your values.
# In development, .env is loaded by the Rust backend.
#
# Provider API keys are configured in-app via Settings.
# No environment variables are required for normal operation.

# ===========================================
# OPTIONAL: Development Settings
# ===========================================

# Enable verbose logging (debug, info, warn, error)
# RUST_LOG=debug
