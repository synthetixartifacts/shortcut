{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ShortCut",
  "version": "0.1.0",
  "identifier": "com.g-prompter.shortcut",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run icons:sync && npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ShortCut",
        "width": 800,
        "height": 600,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "visible": true,
        "center": true
      },
      {
        "label": "indicator",
        "title": "ShortCut Indicator",
        "url": "/indicator",
        "width": 500,
        "height": 120,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "focus": false
      },
      {
        "label": "action-menu",
        "title": "ShortCut Action Menu",
        "url": "/action-menu",
        "width": 280,
        "height": 280,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "focus": false
      },
      {
        "label": "screen-question",
        "title": "ShortCut Screen Question",
        "url": "/screen-question",
        "width": 520,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self'; img-src 'self' data:; media-src 'self' blob:; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "resources": {
      "resources/onnxruntime.dll": "onnxruntime.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "entitlements": null,
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {}
}
